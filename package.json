{
  "name": "japanvip-2.0",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "pnpm --filter @japanvip/db studio"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=7.28.0",
      "nodemailer": ">=9.0.1",
      "postcss": ">=8.5.10"
    }
  },
  "devDependencies": {
    "turbo": "^2.10.0",
    "prettier": "^3.9.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
