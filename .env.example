# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DATABASE_URL="postgresql://japanvip:japanvip_dev_password@localhost:5432/japanvip_db"
POSTGRES_USER=japanvip
POSTGRES_PASSWORD=japanvip_dev_password
POSTGRES_DB=japanvip_db

# ─────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=japanvip_redis_password

# ─────────────────────────────────────────
# NEXTAUTH
# ─────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=your-super-secret-key-min-32-chars

# ─────────────────────────────────────────
# CLOUDFLARE R2
# ─────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=japanvip-media
R2_PUBLIC_URL=https://media.japanvip.vn

# ─────────────────────────────────────────
# EMAIL (Development: MailHog)
# ─────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Japan VIP <noreply@japanvip.vn>"

# ─────────────────────────────────────────
# TYPOGRAPHY (optional override)
# ─────────────────────────────────────────
# Fallback khi DB chưa có setting. Mặc định: be-vietnam-pro
# Giá trị hợp lệ: be-vietnam-pro | inter | noto-sans | roboto | open-sans
# SITE_ACTIVE_FONT=be-vietnam-pro
